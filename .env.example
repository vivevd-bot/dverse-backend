# ===== DVERSE Backend Core — env =====
NODE_ENV=production
PORT=8080

# SQLite — PHẢI trỏ vào VOLUME BỀN trên Railway (không để trong container ephemeral)
DB_PATH=/data/dverse.db

# Secrets (BẮT BUỘC ở production) — sinh bằng: openssl rand -hex 32
JWT_SECRET=
DRM_SECRET=
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
DRM_TOKEN_TTL_SEC=90

# OTP
OTP_PROVIDER=stub        # stub | telco (cắm SMS gateway thật trước golive)
OTP_TTL_SEC=300
OTP_MAX_ATTEMPTS=5

# VNPay (golive)
DVERSE_VNPAY=false
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_RETURN_URL=
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Telco DCB (cắm khi tích hợp)
DCB_ENABLED=false
DCB_CALLBACK_SECRET=

# Security
CORS_ORIGINS=https://vivevd-bot.github.io
RL_WINDOW_SEC=60
RL_AUTH_MAX=10
RL_SPEND_MAX=30
RL_CHAPTER_MAX=40
RL_DEFAULT_MAX=120

# Free-tier "đọc free khi chờ"
FREE_CHAPTERS=10
WAIT_UNLOCK_HOURS=24
